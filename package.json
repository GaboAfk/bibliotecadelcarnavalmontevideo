{
  "name": "biblioteca-carnaval",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "bash -c 'supabase start && npm run generate-types && npm run dev'",
    "reset": "bash -c 'supabase db reset && npm run generate-types'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate-types": "supabase gen types typescript --local --schema public > src/lib/database.types.ts",
    "db:push": "dotenv -e .env.local -- supabase db push --linked",
    "db:reset": "dotenv -e .env.local -- supabase db reset --linked",
    "db:status": "dotenv -e .env.local -- supabase db query --linked \"SELECT COUNT(*) FROM categories; SELECT COUNT(*) FROM agrupaciones;\""
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
